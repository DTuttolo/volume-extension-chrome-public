{
    "manifest_version": 3,
    "name": "Volume Booster 300",
    "version": "1.0.10",
    "description": "Enhances and fine-tunes audio in the active tab, with boost support up to 300% and a convenient popout control window.",
    "icons": {
        "16": "icon.png",
        "32": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs",
        "storage"
    ],
    "action": {
        "default_title": "Volume Booster 300",
        "default_icon": {
            "16": "icon.png",
            "32": "icon.png"
        },
        "default_popup": "popup.html"
    }
}